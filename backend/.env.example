# JWT
JWT_SECRET=dev-secret-change-in-production
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# MongoDB
MONGO_URL=mongodb://root:root@mongo:27017/database?authSource=admin

# Valkey
VALKEY_URL=redis://valkey:6379/0

# Cache
CACHE_TTL_SECONDS=60
CACHE_ENABLED=true

# API
API_PREFIX=/api/v1
LOG_LEVEL=INFO

# Bootstrap (set to "true" to run on startup)
RUN_MIGRATIONS=true
RUN_SEED=true
